rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow authenticated users to write their own demo logs.
    match /logs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.category in ['general', 'medication', 'symptom', 'emergency']
        && request.resource.data.lang in ['zh-HK', 'en-US']
        && request.resource.data.latencyMs is int
        && request.resource.data.latencyMs >= 0
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && request.resource.data.timestamp is timestamp;

      // Allow users to read only their own records.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Disallow client-side updates/deletes for evidence integrity.
      allow update, delete: if false;
    }
  }
}
