rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function canReadHospitalAccount(data) {
      return isSignedIn()
        && (
          data.verificationStatus == 'verified'
          ||
          data.ownerUid == request.auth.uid
          || request.auth.uid in data.admins
          || request.auth.uid in data.members
          || (
            request.auth.token.email != null
            && request.auth.token.email in data.memberEmails
          )
        );
    }

    // Only allow authenticated users to write their own demo logs.
    match /logs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.category in ['general', 'medication', 'symptom', 'emergency']
        && request.resource.data.lang in ['zh-HK', 'en-US']
        && request.resource.data.latencyMs is int
        && request.resource.data.latencyMs >= 0
        && request.resource.data.encryptedText is string
        && request.resource.data.encryptedText.size() <= 10000
        && request.resource.data.timestamp is timestamp;

      // Allow users to read only their own records.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Disallow client-side updates/deletes for evidence integrity.
      allow update, delete: if false;
    }

    // Organization projects (custom hospital rooms + button dashboards)
    match /orgProjects/{projectId} {
      allow read: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          || (
            request.auth.token.email != null
            && request.auth.token.email in resource.data.memberEmails
          )
        );

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.memberEmails is list
        && request.resource.data.memberEmails.size() <= 80
        && request.resource.data.rooms is list
        && request.resource.data.rooms.size() <= 120
        && (
          !('encryptedRooms' in request.resource.data)
          || (
            request.resource.data.encryptedRooms is string
            && request.resource.data.encryptedRooms.size() <= 50000
          )
        );

      // Owner-only updates/deletes (members can view but not modify).
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Hospital account tenants used by staff teams.
    match /hospitalAccounts/{accountId} {
      allow read: if canReadHospitalAccount(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 140
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 6
        && request.resource.data.code.size() <= 16
        && request.resource.data.admins is list
        && request.resource.data.members is list
        && request.resource.data.memberEmails is list
        && request.resource.data.officialDomain is string
        && request.resource.data.officialDomain.size() > 3
        && request.resource.data.officialDomain.size() <= 120
        && request.resource.data.proofUrl is string
        && request.resource.data.proofUrl.size() >= 12
        && request.resource.data.proofUrl.size() <= 1000
        && request.resource.data.verificationStatus == 'pending';

      // Owner/admin can update account membership and metadata.
      allow update: if isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          || request.auth.uid in resource.data.admins
        )
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.verificationStatus == resource.data.verificationStatus;

      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // One membership document per authenticated user.
    match /hospitalMemberships/{uid} {
      allow read, delete: if isSelf(uid);

      allow create, update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.accountId is string
        && request.resource.data.accountId.size() > 0
        && request.resource.data.accountId.size() <= 120
        && request.resource.data.role in ['staff'];
    }

    // One private Gmail-to-role profile per authenticated user.
    match /memberProfiles/{uid} {
      allow read, delete: if isSelf(uid);

      allow create, update: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'role',
          'roleLabel',
          'roleRoute',
          'hospital',
          'hospitalOther',
          'source',
          'updatedAt',
          'updatedAtMs'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ['patient', 'family_member', 'hospital_staff']
        && request.resource.data.roleRoute in ['patient.html', 'family.html', 'staff.html']
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 140
        && request.resource.data.photoURL is string
        && request.resource.data.photoURL.size() <= 1000
        && request.resource.data.hospital is string
        && request.resource.data.hospital.size() <= 140
        && request.resource.data.hospitalOther is string
        && request.resource.data.hospitalOther.size() <= 180
        && request.resource.data.source in ['homepage_role_chooser', 'member_profile_setup']
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAtMs is int;
    }

    // Owner-scoped encrypted chat messages. Plain message text is not allowed.
    match /secureChats/{uid}/messages/{messageId} {
      allow read, delete: if isSelf(uid);

      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'role',
          'roomId',
          'encryptedText',
          'senderName',
          'createdAt',
          'createdAtMs'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ['patient', 'family_member', 'hospital_staff', 'member']
        && request.resource.data.roomId is string
        && request.resource.data.roomId.size() > 0
        && request.resource.data.roomId.size() <= 80
        && request.resource.data.encryptedText is string
        && request.resource.data.encryptedText.matches('^carevoice\\.chat\\.enc\\.v1:.*')
        && request.resource.data.encryptedText.size() <= 12000
        && request.resource.data.senderName is string
        && request.resource.data.senderName.size() <= 140
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAtMs is int;

      allow update: if false;
    }
  }
}
